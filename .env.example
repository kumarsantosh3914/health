# MongoDB connection string (local MongoDB / Compass default shown)
MONGODB_URI=mongodb://localhost:27017/india-health-arena

# Public site URL (used for sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI API key — powers the "Ask AI" feature (gpt-4o-mini). Optional;
# Ask AI returns a friendly "not configured" message when unset.
OPENAI_API_KEY=

# Google Places API (New) key — for `npm run import:places` to pull REAL
# clinic/doctor listings onto the map. Enable "Places API (New)" in GCP.
GOOGLE_MAPS_API_KEY=

# ABDM Healthcare Professionals Registry (HPR) — verifies community-submitted
# doctors. Leave blank for demo mode (OTP 123456). Set both for live verification.
HPR_BASE_URL=
HPR_AUTH_TOKEN=
